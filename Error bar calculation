import matplotlib.pyplot as plt
import math

def plot_all_features_error_bars_grid(df_spots, use_sem=False):
    """
    Plots error bars for all color features across concentrations in a grid (3 plots per row).

    Parameters:
        df_spots : pd.DataFrame
            Spot data with 'Concentration' and color feature columns
        use_sem : bool
            If True, error bars = SEM. If False, error bars = SD
    """
    feature_cols = ["R", "G", "B", "H", "S", "V",
                    "L*", "A*", "B*", "X", "Y", "Z", "Gray", "Delta_E"]

    df_plot = df_spots[df_spots["Label"] != "B"]  # Exclude blanks

    n_features = len(feature_cols)
    n_cols = 3
    n_rows = math.ceil(n_features / n_cols)

    fig, axes = plt.subplots(n_rows, n_cols, figsize=(18, 4 * n_rows))
    axes = axes.flatten()  # Flatten to 1D array for easy indexing

    for i, feature in enumerate(feature_cols):
        grouped = df_plot.groupby("Concentration")[feature]
        means = grouped.mean()
        errors = grouped.sem() if use_sem else grouped.std()
        ylabel = f"{feature} (mean ± {'SEM' if use_sem else 'SD'})"

        ax = axes[i]
        ax.errorbar(
            x=means.index,
            y=means.values,
            yerr=errors,
            fmt='o-', capsize=5, markersize=6,
            ecolor='red', color='blue'
        )
        ax.set_xlabel("Concentration (g/dL)")
        ax.set_ylabel(ylabel)
        ax.set_title(feature)
        ax.grid(True)

    # Turn off any unused subplots
    for j in range(i + 1, len(axes)):
        axes[j].axis('off')

    plt.tight_layout()
    plt.show()


# --- Usage ---
plot_all_features_error_bars_grid(df_spots, use_sem=False)  # SD error bars
# plot_all_features_error_bars_grid(df_spots, use_sem=True)  # SEM error bars

