if __name__ == "__main__":
    final_labels, row_colors, image = detect_and_label_circles("/content/drive/MyDrive/dataset/img6.jpg")
    df_spots, df_stats = create_feature_dataframe_with_pval(final_labels)
    plot_detected_circles(final_labels, image)
    print_feature_table(df_spots)
    print_r2_pval_table(df_stats)

